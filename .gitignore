# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Cargo.lock is intentionally tracked for reproducible builds (see ADR-004)

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Copilot session state (ephemeral per-session artifacts)
.copilot/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Application specific
# Configuration files (may contain sensitive data)
config/
data/
downloads/
podcasts/

# Temporary files
*.tmp
*.temp
*.log

# Test artifacts
test_output/

# Release builds
releases/